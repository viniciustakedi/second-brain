# Copy to `.env` in this folder. Docker Compose loads `.env` automatically (Mac, Windows, Linux).

# ── Vault (required) ──────────────────────────────────────────
# macOS (local vault, recommended as source of truth on disk):
#   VAULT_PATH=/Users/you/path/to/second-brain-obsidian
# macOS (still valid: vault inside iCloud Drive if you want Apple to sync raw files):
#   VAULT_PATH=/Users/you/Library/Mobile Documents/com~apple~CloudDocs/.../second-brain-obsidian
# Windows (local drive — recommended; use forward slashes or escaped backslashes):
#   VAULT_PATH=C:/Users/you/Brain/second-brain-obsidian
VAULT_PATH=/Users/YOUR_USERNAME/path/to/second-brain-obsidian

# ── Batch backup → iCloud folder (optional profile: backup) ───
# If you omit these, Compose uses ./.brain-local/{snapshots,icloud-drop,state} under this repo (gitignored).
# Set explicit absolute paths to put snapshots and SQLite state on a fast local disk and copies in iCloud Drive.
#
# macOS iCloud target example:
#   BRAIN_ICLOUD_BACKUP_DIR=/Users/you/Library/Mobile Documents/com~apple~CloudDocs/second-brain-icloud-backups
# Windows iCloud target example (path varies):
#   BRAIN_ICLOUD_BACKUP_DIR=C:/Users/you/iCloudDrive/second-brain-backups
#
# BRAIN_SNAPSHOT_LOCAL_DIR=/Users/YOUR_USERNAME/path/to/local-snapshot-folder
# BRAIN_ICLOUD_BACKUP_DIR=/Users/YOUR_USERNAME/path/to/icloud-backup-folder
# BRAIN_STATE_DIR=/Users/YOUR_USERNAME/path/to/backup-state

# Local time for daily full snapshot (container TZ, see TZ below)
BACKUP_SNAPSHOT_TIME=23:59
BACKUP_RETENTION_LOCAL_DAYS=14
BACKUP_RETENTION_ICLOUD_DAYS=30
BACKUP_RETRY_COPY_INTERVAL_SEC=900
# Comma-separated glob patterns relative to vault root (optional)
# BACKUP_EXCLUDE_GLOBS=.trash/**,**/.DS_Store
BACKUP_LOG_LEVEL=INFO
# Set to true to run one snapshot immediately on container start (in addition to the daily schedule)
BACKUP_RUN_ON_START=false
# IANA timezone for the scheduler (examples: America/Sao_Paulo, Europe/Lisbon, UTC)
TZ=UTC

OLLAMA_PORT=11434
CHROMA_PORT=8000
MCP_PORT=3777

# ── OAuth 2.0 (required for remote/tunnel access) ─────────────
# Leave empty to run without authentication (localhost only).
#
# OAUTH_PASSWORD  — password shown on the login page when Claude web authorizes.
#                   Choose something strong; this is the only credential protecting your vault.
#                   Generate: openssl rand -base64 24
#
# JWT_SECRET      — secret used to sign/verify access tokens (never share this).
#                   Generate: openssl rand -hex 32
#
# PUBLIC_URL      — your Cloudflare Tunnel public URL (no trailing slash).
#                   Used in OAuth metadata so clients know where to redirect.
#                   Example: https://xxx.trycloudflare.com
#
# JWT_EXPIRY_DAYS — how many days a token stays valid before the user must re-login (default: 7).
#
OAUTH_PASSWORD=
JWT_SECRET=
PUBLIC_URL=https://xxx.trycloudflare.com
JWT_EXPIRY_DAYS=7
