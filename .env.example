# Copy to `.env` in this folder. Docker Compose loads `.env` automatically (Mac, Windows, Linux).

# ── Vault (required) ──────────────────────────────────────────
# MCP `save_note` writes under:  $VAULT_PATH/<folder>/YYYY-MM-DD-slug.md
#
# Suggested Mac layout (notes under Documents; backup zips go to a separate iCloud folder):
#   ~/Documents/second-brain/memories     ← VAULT_PATH (.md notes)
#   ~/Documents/second-brain/snapshots    ← local zips + optional state/
#
# macOS — vault only under Documents (recommended for this project):
#   VAULT_PATH=/Users/YOU/Documents/second-brain/memories
#
# macOS — vault inside iCloud Drive (if you want Apple file-by-file sync):
#   VAULT_PATH=/Users/YOU/Library/Mobile Documents/com~apple~CloudDocs/second-brain/memories
#
# Windows:
#   VAULT_PATH=C:/Users/YOU/Documents/second-brain/memories
#
VAULT_PATH=/Users/YOUR_USERNAME/Documents/second-brain/memories

# ── Batch backup → iCloud “drop” folder (Docker profile: backup) ───
# The MCP does NOT write notes here — only zip copies from the backup job.
#
# macOS (typical iCloud Drive path):
#   BRAIN_ICLOUD_BACKUP_DIR=/Users/YOU/Library/Mobile Documents/com~apple~CloudDocs/second-brain/backup
#
# Windows (iCloud for Windows):
#   BRAIN_ICLOUD_BACKUP_DIR=C:/Users/YOU/iCloudDrive/second-brain/backup
#
BRAIN_SNAPSHOT_LOCAL_DIR=/Users/YOUR_USERNAME/Documents/second-brain/snapshots
BRAIN_ICLOUD_BACKUP_DIR=/Users/YOUR_USERNAME/Library/Mobile Documents/com~apple~CloudDocs/second-brain/backup
BRAIN_STATE_DIR=/Users/YOUR_USERNAME/Documents/second-brain/snapshots/state

# Local time for daily full snapshot (container TZ, see TZ below)
BACKUP_SNAPSHOT_TIME=23:59
BACKUP_RETENTION_LOCAL_DAYS=14
BACKUP_RETENTION_ICLOUD_DAYS=30
BACKUP_RETRY_COPY_INTERVAL_SEC=900
# Comma-separated glob patterns relative to vault root (optional)
# BACKUP_EXCLUDE_GLOBS=.trash/**,**/.DS_Store
BACKUP_LOG_LEVEL=INFO
# Set to true to run one snapshot immediately on container start (in addition to the daily schedule)
BACKUP_RUN_ON_START=false
# IANA timezone for the scheduler (examples: America/Sao_Paulo, Europe/Lisbon, UTC)
TZ=America/Sao_Paulo

OLLAMA_PORT=11434
CHROMA_PORT=8000
MCP_PORT=3777

# ── OAuth 2.0 (required for remote/tunnel access) ─────────────
# Leave empty to run without authentication (localhost only).
#
# OAUTH_PASSWORD  — password shown on the login page when Claude web authorizes.
#                   Choose something strong; this is the only credential protecting your vault.
#                   Generate: openssl rand -base64 24
#
# JWT_SECRET      — secret used to sign/verify access tokens (never share this).
#                   Generate: openssl rand -hex 32
#
# PUBLIC_URL      — your Cloudflare Tunnel public URL (no trailing slash).
#                   Used in OAuth metadata so clients know where to redirect.
#                   Example: https://xxx.trycloudflare.com
#
# JWT_EXPIRY_DAYS — how many days a token stays valid before the user must re-login (default: 7).
#
OAUTH_PASSWORD=
JWT_SECRET=
PUBLIC_URL=https://xxx.trycloudflare.com
JWT_EXPIRY_DAYS=7
