# -----------------------------------------------------------------------------
# Obsidian vault (private notes + .obsidian metadata)
# -----------------------------------------------------------------------------
# Convention for this repo: keep your vault next to the code as:
#   second-brain-obsidian/
# (friendly name: "Second Brain Obsidian"). If you use a different folder
# name or location, add it here so Markdown and .obsidian never get pushed.
second-brain-obsidian/

# -----------------------------------------------------------------------------
# Secrets — never commit real credentials
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# -----------------------------------------------------------------------------
# OS & editors
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~


.claude/
.cursor/

# Default local backup layout (compose fallbacks); override BRAIN_* in .env for real iCloud paths.
.brain-local/