# -----------------------------------------------------------------------------
# Private data — never commit (Obsidian vault + batch backup artifacts)
# -----------------------------------------------------------------------------
# If your vault or iCloud backup folder lives inside this repo (common with
# iCloud Drive), keep these entries so GitHub only gets the Docker/MCP code.
#
# Obsidian: File → Open Vault… → choose the `memories` folder (your .md + .obsidian).
/memories/

# Zip snapshots + .sha256 sidecars dropped next to the code (e.g. …/second-brain/backup)
/backup/

# Legacy vault folder name (ignore if you still have it next to the repo)
/second-brain-obsidian/

# -----------------------------------------------------------------------------
# Secrets — never commit real credentials
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# -----------------------------------------------------------------------------
# OS & editors
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~


.claude/
.cursor/

# Default local backup layout (Compose fallbacks); override BRAIN_* in .env for real paths.
.brain-local/
